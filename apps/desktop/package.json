{
  "name": "@solryn/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Project Epoch VTT — Electron desktop app. GM hosts a room; players connect through the relay by room code.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@solryn/protocol": "*",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.solryn.vtt",
    "productName": "Project Epoch VTT",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
